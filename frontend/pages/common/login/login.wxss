/* pages/common/login/login.wxss */
.container {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.logo {
  margin-bottom: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  background-color: #007aff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 122, 255, 0.3);
}

.logo .title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.role-selector {
  display: flex;
  width: 100%;
  margin-bottom: 40rpx;
  background-color: #fff;
  border-radius: 8rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.role-tab {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  font-size: 32rpx;
  color: #666;
  border-bottom: 4rpx solid transparent;
  transition: all 0.3s ease;
}

.role-tab.active {
  color: #007aff;
  border-bottom-color: #007aff;
  background-color: #f0f8ff;
}

.role-tab:hover {
  background-color: #f9f9f9;
}

.form-container {
  width: 100%;
  background-color: #fff;
  padding: 40rpx;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item .label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.form-item input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 32rpx;
  background-color: #f9f9f9;
}

.form-item input:focus {
  border-color: #007aff;
  background-color: #fff;
}

.login-tip {
  text-align: center;
  margin-bottom: 30rpx;
  padding: 20rpx;
  background-color: #f0f8ff;
  border-radius: 8rpx;
  border-left: 4rpx solid #007aff;
}

.login-tip text {
  font-size: 28rpx;
  color: #007aff;
}

.login-btn {
  width: 100%;
  height: 80rpx;
  background-color: #007aff;
  color: #fff;
  font-size: 32rpx;
  border-radius: 8rpx;
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-btn:hover {
  background-color: #0066cc;
}

.login-btn[loading] {
  opacity: 0.8;
}
