.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #e5e5e5;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.add-btn {
  background-color: #007aff;
  color: #fff;
  border-radius: 8rpx;
  padding: 12rpx 24rpx;
  font-size: 28rpx;
}

.search-bar {
  display: flex;
  margin-bottom: 30rpx;
  gap: 10rpx;
}

.search-bar input {
  flex: 1;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  padding: 15rpx;
  font-size: 28rpx;
}

.search-btn {
  background-color: #f0f0f0;
  color: #333;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.account-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.account-item {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.account-info {
  margin-bottom: 20rpx;
}

.account-username {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.account-realname {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.account-role {
  display: block;
  font-size: 26rpx;
  color: #999;
}

.account-actions {
  display: flex;
  gap: 10rpx;
  justify-content: flex-end;
}

.edit-btn {
  background-color: #f0f0f0;
  color: #333;
  border-radius: 8rpx;
  padding: 8rpx 16rpx;
  font-size: 24rpx;
}

.delete-btn {
  background-color: #ff3b30;
  color: #fff;
  border-radius: 8rpx;
  padding: 8rpx 16rpx;
  font-size: 24rpx;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.modal-content {
  padding: 20rpx 0;
}

.form-item {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.form-item input,
.form-item picker {
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  padding: 15rpx;
  font-size: 28rpx;
  width: 100%;
}

.picker {
  font-size: 28rpx;
  color: #333;
}
