<view class="container">
  <view class="header">
    <text class="title">{{parentId ? '编辑家长' : '添加家长'}}</text>
  </view>
  
  <view class="form-container">
    <view class="form-item">
      <text class="label">家长姓名</text>
      <input type="text" placeholder="请输入家长姓名" value="{{parent.nickname}}" bindinput="inputNickname" />
    </view>
    
    <view class="form-item">
      <text class="label">手机号管理</text>
      <view class="phones-container">
        <view class="phone-item" wx:for="{{parent.phones}}" wx:key="index">
          <input type="number" placeholder="请输入手机号" value="{{item}}" bindinput="inputPhone" data-index="{{index}}" />
          <button class="delete-phone-btn" bindtap="deletePhone" data-index="{{index}}">-</button>
        </view>
        <button class="add-phone-btn" bindtap="addPhone">+ 添加手机号</button>
      </view>
    </view>
    
    <view class="form-item">
      <text class="label">备注</text>
      <textarea placeholder="请输入备注信息" value="{{parent.remark}}" bindinput="inputRemark" />
    </view>
    
    <view class="form-item">
      <text class="label">关联订单</text>
      <switch checked="{{createOrder}}" bindchange="toggleCreateOrder" />
    </view>
    
    <view class="order-form" wx:if="{{createOrder}}">
      <view class="form-item">
        <text class="label">订单金额</text>
        <input type="number" placeholder="请输入订单金额" value="{{orderAmount}}" bindinput="inputOrderAmount" />
      </view>
      
      <view class="form-item">
        <text class="label">课时数量</text>
        <input type="number" placeholder="请输入课时数量" value="{{lessonCount}}" bindinput="inputLessonCount" />
      </view>
      
      <view class="form-item">
        <text class="label">课程名称</text>
        <input type="text" placeholder="请输入课程名称" value="{{courseName}}" bindinput="inputCourseName" />
      </view>
    </view>
  </view>
  
  <button class="save-btn" bindtap="saveParent">保存</button>
</view>