.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.header {
  margin-bottom: 40rpx;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #e5e5e5;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
}

.form-container {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.form-item input,
.form-item textarea {
  width: 100%;
  padding: 20rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  font-size: 28rpx;
  background-color: #f9f9f9;
}

.form-item textarea {
  height: 150rpx;
  resize: none;
}

.phones-container {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.phone-item {
  display: flex;
  gap: 15rpx;
  align-items: center;
}

.phone-item input {
  flex: 1;
  height: 80rpx;
}

.delete-phone-btn {
  width: 60rpx;
  height: 60rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  background-color: #fff;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
}

.add-phone-btn {
  width: 100%;
  height: 80rpx;
  border: 1rpx dashed #007aff;
  border-radius: 8rpx;
  background-color: #f0f8ff;
  color: #007aff;
  font-size: 28rpx;
  margin-top: 10rpx;
}

.save-btn {
  width: 100%;
  height: 90rpx;
  background-color: #007aff;
  color: #fff;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: bold;
}