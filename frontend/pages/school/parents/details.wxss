.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.header {
  margin-bottom: 40rpx;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #e5e5e5;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
}

.info-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #e5e5e5;
}

.info-item {
  display: flex;
  margin-bottom: 15rpx;
  align-items: flex-start;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 28rpx;
  color: #666;
  width: 120rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  word-break: break-all;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.order-item {
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  padding: 20rpx;
  background-color: #f9f9f9;
}

.order-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 15rpx;
}

.order-id {
  font-size: 26rpx;
  color: #333;
  font-weight: bold;
}

.order-date {
  font-size: 24rpx;
  color: #999;
}

.order-details {
  display: flex;
  justify-content: space-between;
  margin-bottom: 15rpx;
}

.order-status {
  font-size: 26rpx;
  color: #007aff;
  font-weight: bold;
}

.order-amount {
  font-size: 26rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.lesson-packages {
  margin-top: 15rpx;
}

.package-title {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
  display: block;
}

.package-item {
  display: flex;
  align-items: center;
  gap: 15rpx;
  padding: 10rpx 0;
  border-top: 1rpx solid #e5e5e5;
}

.package-name {
  font-size: 26rpx;
  color: #333;
  flex: 1;
}

.package-count {
  font-size: 26rpx;
  color: #666;
}

.package-remaining {
  font-size: 24rpx;
  color: #999;
}

.empty {
  text-align: center;
  padding: 50rpx 0;
  color: #999;
  font-size: 28rpx;
}

.edit-btn,
.add-order-btn {
  width: 100%;
  height: 90rpx;
  border: 1rpx solid #007aff;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.edit-btn {
  background-color: #fff;
  color: #007aff;
}

.add-order-btn {
  background-color: #007aff;
  color: #fff;
}