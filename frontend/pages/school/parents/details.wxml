<view class="container">
  <view class="header">
    <text class="title">家长详情</text>
  </view>
  
  <view class="info-section">
    <text class="section-title">基本信息</text>
    <view class="info-item">
      <text class="info-label">姓名：</text>
      <text class="info-value">{{parent.nickname}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">手机号：</text>
      <text class="info-value">{{parent.phones ? parent.phones.join(', ') : '未设置'}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">备注：</text>
      <text class="info-value">{{parent.remark || '无'}}</text>
    </view>
  </view>
  
  <view class="info-section">
    <text class="section-title">订单信息</text>
    <view class="order-list">
      <view class="order-item" wx:for="{{parent.orders}}" wx:key="id">
        <view class="order-header">
          <text class="order-id">订单号：{{item.order_id}}</text>
          <text class="order-date">{{item.created_at}}</text>
        </view>
        <view class="order-details">
          <text class="order-status">{{item.status}}</text>
          <text class="order-amount">金额：¥{{item.amount}}</text>
        </view>
        <view class="lesson-packages">
          <text class="package-title">课时包：</text>
          <view class="package-item" wx:for="{{item.lesson_packages}}" wx:key="id">
            <text class="package-name">{{item.course_name}}</text>
            <text class="package-count">{{item.total_lessons}}课时</text>
            <text class="package-remaining">(剩余{{item.remaining_lessons}}课时)</text>
          </view>
        </view>
      </view>
    </view>
    <view class="empty" wx:if="{{!parent.orders || parent.orders.length === 0}}">
      <text>暂无订单</text>
    </view>
  </view>
  
  <button class="edit-btn" bindtap="editParent">编辑家长信息</button>
  <!-- <button class="add-order-btn" bindtap="addOrder">添加订单</button> -->
</view>