.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.header {
  margin-bottom: 40rpx;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #e5e5e5;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
}

.form-container {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.picker {
  font-size: 28rpx;
  color: #333;
  padding: 20rpx 0;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  padding-left: 20rpx;
  background-color: #f9f9f9;
}

.form-item input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  font-size: 28rpx;
  background-color: #f9f9f9;
}

.value {
  font-size: 28rpx;
  color: #007aff;
  font-weight: bold;
  padding: 20rpx 0;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  padding-left: 20rpx;
  background-color: #f9f9f9;
}

.consume-btn {
  width: 100%;
  height: 90rpx;
  background-color: #007aff;
  color: #fff;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: bold;
}