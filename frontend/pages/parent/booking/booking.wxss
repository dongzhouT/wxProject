.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.course-list {
  background-color: #fff;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.course-item {
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.course-info {
  width: 100%;
  margin-bottom: 20rpx;
}

.course-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.course-schedule {
  margin-bottom: 10rpx;
}

.schedule-label {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 5rpx;
}

.schedule-item {
  display: block;
  font-size: 24rpx;
  color: #333;
  margin-bottom: 3rpx;
  padding-left: 20rpx;
}

.course-teacher {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.course-remaining {
  display: block;
  font-size: 24rpx;
  color: #ff4d4f;
  margin-bottom: 15rpx;
}

.button-group {
  display: flex;
  justify-content: flex-end;
  gap: 10rpx;
}

.book-btn {
  width: 120rpx;
  height: 60rpx;
  background-color: #1989fa;
  color: #fff;
  font-size: 26rpx;
  border-radius: 8rpx;
}

.book-btn::after {
  border-radius: 8rpx;
}

.book-btn[disabled] {
  background-color: #ccc;
  color: #fff;
}

.cancel-btn {
  width: 120rpx;
  height: 60rpx;
  background-color: #fff;
  color: #ff4d4f;
  font-size: 26rpx;
  border-radius: 8rpx;
  border: 1rpx solid #ff4d4f;
}

.cancel-btn::after {
  border-radius: 8rpx;
}

.empty {
  background-color: #fff;
  padding: 60rpx;
  text-align: center;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  margin-top: 20rpx;
}

.empty text {
  font-size: 28rpx;
  color: #999;
}