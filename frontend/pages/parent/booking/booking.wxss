.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.course-list {
  background-color: #fff;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.course-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.course-info {
  flex: 1;
}

.course-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
}

.course-time {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 5rpx;
}

.course-teacher {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 5rpx;
}

.course-remaining {
  display: block;
  font-size: 24rpx;
  color: #ff4d4f;
}

.book-btn {
  width: 120rpx;
  height: 60rpx;
  background-color: #1989fa;
  color: #fff;
  font-size: 26rpx;
  border-radius: 8rpx;
  margin-left: 20rpx;
}

.book-btn::after {
  border-radius: 8rpx;
}

.empty {
  background-color: #fff;
  padding: 60rpx;
  text-align: center;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  margin-top: 20rpx;
}

.empty text {
  font-size: 28rpx;
  color: #999;
}