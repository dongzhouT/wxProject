.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.notification-list {
  background-color: #fff;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.notification-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  position: relative;
}

.notification-time {
  width: 120rpx;
  font-size: 24rpx;
  color: #999;
}

.notification-content {
  flex: 1;
  margin-left: 20rpx;
  font-size: 26rpx;
  color: #333;
  line-height: 36rpx;
}

.notification-status {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
}

.status-dot {
  display: inline-block;
  width: 10rpx;
  height: 10rpx;
  background-color: #ff4d4f;
  border-radius: 50%;
}

.empty {
  background-color: #fff;
  padding: 60rpx;
  text-align: center;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  margin-top: 20rpx;
}

.empty text {
  font-size: 28rpx;
  color: #999;
}